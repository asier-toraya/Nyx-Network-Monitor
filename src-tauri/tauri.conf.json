{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Nyx Net Sentinel",
  "version": "0.1.0",
  "identifier": "com.asier.sentineldesk",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://localhost:1420",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Nyx Net Sentinel",
        "width": 1600,
        "height": 980,
        "minWidth": 1180,
        "minHeight": 760,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis", "msi"],
    "publisher": "Asier Gonzalez",
    "homepage": "https://github.com/asier-toraya",
    "shortDescription": "Desktop network visibility with explainable risk scoring for Windows hosts.",
    "longDescription": "Nyx Net Sentinel is a Windows-first desktop application built with Tauri, React and Rust to monitor live connections, enrich them with process and destination context, and help analysts triage network activity with clear, explainable risk scoring.",
    "copyright": "Copyright © 2026 Asier Gonzalez",
    "icon": ["icons/icon.ico"],
    "windows": {
      "webviewInstallMode": {
        "type": "downloadBootstrapper",
        "silent": true
      },
      "nsis": {
        "installerIcon": "icons/icon.ico",
        "languages": ["Spanish", "English"],
        "displayLanguageSelector": false,
        "installMode": "currentUser",
        "startMenuFolder": "Nyx Net Sentinel"
      },
      "wix": {
        "upgradeCode": "7f54cbc6-fd33-527f-95c3-f2c541c6adb1"
      }
    }
  }
}
