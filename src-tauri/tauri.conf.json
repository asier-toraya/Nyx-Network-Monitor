{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Nyx Net Sentinel",
  "version": "0.1.0",
  "identifier": "com.asier.sentineldesk",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://localhost:1420",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Nyx Net Sentinel",
        "width": 1600,
        "height": 980,
        "minWidth": 1180,
        "minHeight": 760,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": ["icons/icon.ico"]
  }
}
